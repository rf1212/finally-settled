      },
      {
        "id": "node_06",
        "name": "Check Status",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1260,
          300
        ],
        "parameters": {
          "language": "javaScript",
          "mode": "runOnceForAllItems",
          "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.pollCount = (staticData.pollCount || 0) + 1;\nconst pollCount = staticData.pollCount;\nconst response = $input.first().json;\nconst status = response.data.status;\nconst runId = response.data.id;\nlet action = 'continue';\nlet errorMessage = '';\nif (status === 'SUCCEEDED') {\n  action = 'succeeded';\n  staticData.pollCount = 0;\n} else if (status === 'FAILED' || status === 'ABORTED' || status === 'TIMED-OUT') {\n  action = 'failed';\n  errorMessage = 'Apify run status: ' + status;\n  staticData.pollCount = 0;\n} else if (pollCount >= 30) {\n  action = 'failed';\n  errorMessage = 'Polling timeout: exceeded 15 minutes';\n  staticData.pollCount = 0;\n}\nreturn [{ json: { runId, pollCount, status, action, errorMessage } }];"
        }
      },
