        100
      ],
      "parameters": {
        "method": "PATCH",
        "url": "https://api.airtable.com/v0/appLmQyh1ov0NDQ58/tblJBrj6XNjap4wQb",
        "authentication": "predefinedCredentialType",
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ $json.payload }}",
        "options": {
          "batching": {
            "batch": {
              "batchSize": 1,
              "batchInterval": 500
            }
          },
          "timeout": 30000
        },
        "nodeCredentialType": "airtableTokenApi"
      },
      "notes": "Upserts records to Airtable in batches of 10. Assign your Airtable HTTP Header Auth credential here. Retries 3x on failure (rate limits).",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "credentials": {
        "airtableTokenApi": {
          "id": "BPWOrtwLe4IsJIrh",
          "name": "Airtable Personal Access Token account"
        }
      }
    },
    {
      "id": "node_13",
      "name": "Aggregate Counts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2700,
        100
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nlet totalCreated = 0;\nlet totalUpdated = 0;\nfor (const item of items) {\n  totalCreated += (item.json.createdRecords || []).length;\n  totalUpdated += (item.json.updatedRecords || []).length;\n}\nconst now = new Date();\nlet runId = '';\ntry { runId = $('Check Status').first().json.runId; } catch(e) { runId = 'unknown'; }\nreturn [{\n  json: {\n    recordsAdded: totalCreated,\n    recordsUpdated: totalUpdated,\n    total: totalCreated + totalUpdated,\n    runDate: now.toISOString(),\n    date: now.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),\n    runId: runId\n  }\n}];"
      }
    },
    {
