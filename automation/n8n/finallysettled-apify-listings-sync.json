        "name": "Aggregate Counts",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2700,
          100
        ],
        "parameters": {
          "language": "javaScript",
          "mode": "runOnceForAllItems",
          "jsCode": "const items = $input.all();\nlet totalCreated = 0;\nlet totalUpdated = 0;\nfor (const item of items) {\n  totalCreated += (item.json.createdRecords || []).length;\n  totalUpdated += (item.json.updatedRecords || []).length;\n}\nconst now = new Date();\nlet runId = '';\ntry { runId = $('Check Status').first().json.runId; } catch(e) { runId = 'unknown'; }\nreturn [{\n  json: {\n    recordsAdded: totalCreated,\n    recordsUpdated: totalUpdated,\n    total: totalCreated + totalUpdated,\n    runDate: now.toISOString(),\n    date: now.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),\n    runId: runId\n  }\n}];"
        }
