        "resume": "timeInterval",
        "amount": 30,
        "unit": "seconds"
      }
    },
    {
      "id": "node_05",
      "name": "Poll Run Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1020,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://api.apify.com/v2/actor-runs/{{ $json.runId }}?token=REDACTED",
        "authentication": "none",
        "options": {}
      },
      "notes": "Polls Apify run status every 30s. Assign your Apify HTTP Header Auth credential here."
    },
    {
      "id": "node_06",
      "name": "Check Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1260,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.pollCount = (staticData.pollCount || 0) + 1;\nconst pollCount = staticData.pollCount;\nconst response = $input.first().json;\nconst status = response.data.status;\nconst runId = response.data.id;\nlet action = 'continue';\nlet errorMessage = '';\nif (status === 'SUCCEEDED') {\n  action = 'succeeded';\n  staticData.pollCount = 0;\n} else if (status === 'FAILED' || status === 'ABORTED' || status === 'TIMED-OUT') {\n  action = 'failed';\n  errorMessage = 'Apify run status: ' + status;\n  staticData.pollCount = 0;\n} else if (pollCount >= 30) {\n  action = 'failed';\n  errorMessage = 'Polling timeout: exceeded 15 minutes';\n  staticData.pollCount = 0;\n}\nreturn [{ json: { runId, pollCount, status, action, errorMessage } }];"
      }
    },
    {
      "id": "node_07",
      "name": "Is Succeeded",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1500,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "cond_succeeded",
              "operator": {
                "type": "string",
                "operation": "equals"
              },
              "leftValue": "={{ $json.action }}",
              "rightValue": "succeeded"
            }
          ]
        },
        "options": {}
      }
    },
    {
