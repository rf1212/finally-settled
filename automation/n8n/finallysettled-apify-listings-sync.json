    {
      "id": "node_03",
      "name": "Extract Run ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        300
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.pollCount = 0;\nconst response = $input.first().json;\nconst runId = response.data.id;\nreturn [{ json: { runId } }];"
      }
    },
    {
      "id": "node_04",
      "name": "Wait 30s",
