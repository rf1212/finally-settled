        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          1020,
          300
        ],
        "parameters": {
          "method": "GET",
          "url": "=https://api.apify.com/v2/actor-runs/{{ $json.runId }}?token=REDACTED",
          "authentication": "none",
          "options": {}
        },
