      {
        "id": "node_09",
        "name": "Fetch Dataset",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          1740,
          100
        ],
        "parameters": {
          "method": "GET",
          "url": "=https://api.apify.com/v2/actor-runs/{{ $('Check Status').first().json.runId }}/dataset/items?token=REDACTED",
          "authentication": "none",
          "options": {}
        },
        "notes": "Fetches scraped listings from Apify. Assign your Apify HTTP Header Auth credential here."
      },
      {
        "id": "node_10",
        "name": "Map 34 Fields",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1980,
          100
        ],
        "parameters": {
          "language": "javaScript",
          "mode": "runOnceForAllItems",
          "jsCode": "let rawItems = $input.all();\nif (rawItems.length === 1 && Array.isArray(rawItems[0].json)) {\n  rawItems = rawItems[0].json.map(item => ({ json: item }));\n}\nreturn rawItems.map(item => {\n  const d = item.json;\n  return { json: {\n    'zpid': String(d.zpid),\n    'Raw home status ': d.rawHomeStatus,\n    'Marketing status simplified ': d.marketingStatusSimplified,\n    'imgSrc': d.imgSrc,\n    'Has image': d.hasImage,\n    'detailUrl': d.detailUrl,\n    'Status type': d.statusType,\n    'statusText': d.statusText,\n    'Address': d.address,\n    'Address street': d.addressStreet,\n    'Address city': d.addressCity,\n    'Address state': d.addressState,\n    'Address zipcode': d.addressZipcode ? Number(d.addressZipcode) : null,\n    'Beds': d.beds,\n    'Sqft': d.area,\n    'Lat long latitude': d.latLong?.latitude,\n    'Lat long longitude': d.latLong?.longitude,\n    'Price': d.hdpData?.homeInfo?.price,\n    'Baths': d.hdpData?.homeInfo?.bathrooms,\n    'Hdp data home info days on zillow': d.hdpData?.homeInfo?.daysOnZillow,\n    'Hdp data home info country': d.hdpData?.homeInfo?.country,\n    'Hdp data home info tax assessed value': d.hdpData?.homeInfo?.taxAssessedValue,\n    'Hdp data home info lot area value': d.hdpData?.homeInfo?.lotAreaValue,\n    'Hdp data home info lot area unit': d.hdpData?.homeInfo?.lotAreaUnit,\n    'Broker name': d.brokerName,\n    'Photos': d.carouselPhotos?.[0]?.baseUrl,\n    'carouselBaseUrl': d.carouselPhotos?.[0]?.communityBaseUrl,\n    'Carousel photos composable photo data photo key': d.carouselPhotos?.[0]?.photoData?.photoKey,\n    'Found from search url': d.foundFromSearchUrl,\n    'Hdp data home info date price changed': d.hdpData?.homeInfo?.datePriceChanged,\n    'Hdp data home info rent zestimate': d.hdpData?.homeInfo?.rentZestimate,\n    'Hdp data home info price reduction': d.hdpData?.homeInfo?.priceReduction,\n    'Zestimate': d.zestimate\n  }};\n});"
        }
      },
      {
        "id": "node_11",
        "name": "Prepare Batches",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2220,
          100
        ],
        "parameters": {
          "language": "javaScript",
          "mode": "runOnceForAllItems",
          "jsCode": "const items = $input.all();\nconst batchSize = 10;\nconst batches = [];\nfor (let i = 0; i < items.length; i += batchSize) {\n  const batch = items.slice(i, i + batchSize);\n  const records = batch.map(item => ({ fields: item.json }));\n  batches.push({\n    json: {\n      payload: JSON.stringify({\n        performUpsert: { fieldsToMergeOn: ['zpid'] },\n        records: records\n      })\n    }\n  });\n}\nreturn batches;"
        }
