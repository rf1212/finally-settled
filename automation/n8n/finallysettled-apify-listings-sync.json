      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2940,
        100
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const d = $json;\nconst lines = [\n  'From: info@rawfunds.com',\n  'To: info@rawfunds.com',\n  'Subject: FinallySettled Listings Sync Complete - ' + d.date,\n  'Content-Type: text/html; charset=utf-8',\n  '',\n  '<h2>Sync Complete</h2><ul><li><b>Records added:</b> ' + d.recordsAdded + '</li><li><b>Records updated:</b> ' + d.recordsUpdated + '</li><li><b>Total:</b> ' + d.total + '</li><li><b>Run ID:</b> ' + d.runId + '</li><li><b>Date:</b> ' + d.runDate + '</li></ul><p><a href=\"https://n8n.autogrowthhub.com\">Open n8n</a></p>'\n];\nconst raw = Buffer.from(lines.join('\\r\\n')).toString('base64url');\nreturn [{ json: { raw } }];"
      }
