    {
      "id": "node-05",
      "name": "Code: Validate Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
      ],
      "parameters": {
        "jsCode": "const record = $('IF: Has Record').first().json.records[0];\nconst fields = record.fields;\nconst errors = [];\n\nconst required = ['HOOK','SUBHOOK','CTA','CAPTION','EXTERIOR_ASSET_ID'];\nfor (const f of required) {\n  if (!fields[f] || String(fields[f]).trim() === '') {\n    errors.push(`Missing required field: ${f}`);\n  }\n}\n\nif (fields.HOOK && fields.HOOK.length > 40) {\n  errors.push(`HOOK too long (${fields.HOOK.length}/40 chars)`);\n}\nif (fields.SUBHOOK && fields.SUBHOOK.length > 40) {\n  errors.push(`SUBHOOK too long (${fields.SUBHOOK.length}/40 chars)`);\n}\n\nlet cta_line1 = '';\nlet cta_line2 = '';\nif (fields.CTA) {\n  let parts;\n  if (fields.CTA.includes('\\n')) {\n    parts = fields.CTA.split('\\n').map(s => s.trim()).filter(s => s);\n  } else if (fields.CTA.includes('.')) {\n    parts = fields.CTA.split('.').map(s => s.trim()).filter(s => s);\n  } else {\n    parts = [fields.CTA.trim()];\n  }\n  cta_line1 = parts[0] || '';\n  cta_line2 = parts[1] || '';\n  if (cta_line1.length > 45) errors.push(`CTA line 1 too long (${cta_line1.length}/45)`);\n  if (cta_line2.length > 45) errors.push(`CTA line 2 too long (${cta_line2.length}/45)`);\n}\n\nconst extUrl = fields.EXTERIOR_ASSET_ID || '';\nif (extUrl && !extUrl.match(/^https?:\\/\\/.+/)) {\n  errors.push('EXTERIOR_ASSET_ID is not a valid URL');\n}\n\nconst valid = errors.length === 0;\n\nreturn [{\n  json: {\n    valid,\n    errors,\n    recordId: record.id,\n    hook: fields.HOOK,\n    subhook: fields.SUBHOOK,\n    cta: fields.CTA,\n    cta_line1,\n    cta_line2,\n    caption: fields.CAPTION,\n    first_comment: fields.FIRST_COMMENT || '',\n    city: fields.CITY || '',\n    exterior_url: fields.EXTERIOR_ASSET_ID,\n    kitchen_url: fields.KITCHEN_ASSET_ID || '',\n    bath_url: fields.BATH_ASSET_ID || '',\n    bedroom_url: fields.BEDROOM_ASSET_ID || '',\n    retry_count: fields.retry_count || 0\n  }\n}];"
      }
    },
