      ],
      "parameters": {
        "jsCode": "const draftResult = $json;\nconst failures = (draftResult.payload && draftResult.payload.failures) ? draftResult.payload.failures : {};\nconst hasFailures = Object.keys(failures).length > 0;\n\nif (hasFailures) {\n  const msgs = [];\n  for (const [key, errs] of Object.entries(failures)) {\n    for (const err of errs) {\n      msgs.push((err.provider || 'unknown') + ': ' + (err.message || 'Unknown error'));\n    }\n  }\n  return [{ json: { draftSucceeded: false, errorMessage: msgs.join('; ') } }];\n}\n\nreturn [{ json: { draftSucceeded: true, errorMessage: '' } }];"
      }
