    {
      "id": "node-07",
      "name": "Code: Build Image List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        0
      ],
      "parameters": {
        "jsCode": "const prev = $('Code: Validate Record').first().json;\n\nconst image_urls = [prev.exterior_url];\nif (prev.kitchen_url) image_urls.push(prev.kitchen_url);\nif (prev.bath_url) image_urls.push(prev.bath_url);\nif (prev.bedroom_url) image_urls.push(prev.bedroom_url);\n\nconst warnings = [];\nif (image_urls.length < 4) {\n  warnings.push(`Only ${image_urls.length}/4 images available`);\n}\n\nreturn [{\n  json: {\n    ...prev,\n    image_urls,\n    image_count: image_urls.length,\n    warnings\n  }\n}];"
      }
    },
