      "parameters": {
        "jsCode": "const data = $('Code: Build Image List').first().json;\n\nconst city = data.city || '';\nconst subheadline = city ? `Available Now in ${city}` : 'Available Now';\n\nconst payload = {\n  image_urls: data.image_urls,\n  headline_line1: data.hook.toUpperCase(),\n  headline_line2: data.subhook.toUpperCase(),\n  subheadline: subheadline,\n  cta_line1: data.cta_line1,\n  cta_line2: data.cta_line2\n};\n\nreturn [{\n  json: {\n    ...data,\n    render_payload: payload\n  }\n}];"
