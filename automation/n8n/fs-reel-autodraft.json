      "parameters": {
        "jsCode": "const validationData = $('Code: Validate Record').first().json;\nconst recordId = validationData.recordId;\nconst currentRetry = validationData.retry_count || 0;\nconst newRetry = currentRetry + 1;\nconst draftResult = $('Code: Check Draft Result').first().json;\nconst errorMsg = draftResult.errorMessage || 'Unknown Publer draft error';\nconst newStatus = newRetry >= 3 ? 'failed_permanent' : 'failed';\n\nreturn [{\n  json: {\n    recordId,\n    updatePayload: {\n      fields: {\n        workflow_status: newStatus,\n        publer_status: 'draft_failed',\n        error_message: '[' + new Date().toISOString() + '] Draft failed: ' + errorMsg,\n        retry_count: newRetry\n      }\n    }\n  }\n}];"
      }
